0x1L VERSIONINFO
FILEVERSION @VERSION_MAJOR@,@VERSION_MINOR@,0,0
{
    BLOCK "VarFileInfo"
    {
        // English language (0x409) and the Windows Unicode codepage (1200)
        VALUE "Translation", 0x409, 1200
    }
    BLOCK "StringFileInfo"
    {
        BLOCK "040904b0"
        {
            VALUE "FileDescription", "A program to show what process locks a file or folder\0"
            VALUE "ProductVersion", "@VERSION_STRING@\0"
            VALUE "ProductName", "Handle2\0"
            VALUE "CompanyName", "PolarGoose\0"
            VALUE "Info", "https://github.com/PolarGoose/Handle2\0"
        }
    }
}
